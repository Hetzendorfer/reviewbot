{
  "name": "reviewbot",
  "version": "1.0.0",
  "type": "module",
  "workspaces": ["frontend"],
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "dev:frontend": "bun run --filter reviewbot-frontend dev",
    "build:frontend": "bun run --filter reviewbot-frontend build",
    "typecheck": "bunx tsc --noEmit && bunx tsc --noEmit -p frontend/tsconfig.json",
    "start": "bun run src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test": "bun test"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.12",
    "@ai-sdk/google": "^2.0.18",
    "@ai-sdk/openai": "^2.0.31",
    "@ai-sdk/openai-compatible": "^0.2.12",
    "@elysiajs/cors": "^1.4.1",
    "@octokit/auth-app": "^7.2.2",
    "@octokit/webhooks": "^13.9.1",
    "ai": "^5.0.66",
    "drizzle-orm": "^0.38.4",
    "elysia": "^1.4.28",
    "minimatch": "^10.2.5",
    "octokit": "^4.1.4",
    "postgres": "^3.4.9",
    "yaml": "^2.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "drizzle-kit": "^0.30.6",
    "typescript": "^5.9.3"
  }
}
